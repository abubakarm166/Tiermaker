# TierMaker Backend - copy to .env and adjust

# Required in production
SECRET_KEY=your-secret-key-at-least-50-chars

# Debug (set False in production)
DEBUG=True

# Comma-separated allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: PostgreSQL (if set, overrides SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/tiermaker

# Optional: CORS origins when DEBUG=False (comma-separated)
# CORS_ORIGINS=https://yourfrontend.com

# JWT (optional overrides in code)
# ACCESS_TOKEN_LIFETIME=60
# REFRESH_TOKEN_LIFETIME=10080
